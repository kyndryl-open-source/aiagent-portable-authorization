# Portable Authorization — Enforcement Engine
PORT=3200
NODE_ENV=development

# PostgreSQL (shared instance, portauth_ table prefix)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portauth

# Admin API key for admin endpoints
ADMIN_API_KEY=dev-engine-key-change-me

# Receiver identity for audience binding
PORTAUTH_EVALUATOR_ID=http://localhost:3200
PORTAUTH_ENGINE_AUDIENCE=http://localhost:3200

# Request-bound proof of possession
PORTAUTH_REQUIRE_PROOF_OF_POSSESSION=false
PORTAUTH_PROOF_MAX_AGE_SECONDS=300

# Tier 2 X.509 trust fallback. Prefer /admin/issuers registry fields.
PORTAUTH_X509_TRUST_ANCHOR_PEM=
PORTAUTH_X509_TRUST_ANCHOR_SHA256=
PORTAUTH_X509_REVOCATION_POLICY=soft-fail

# JWKS cache TTL in seconds (for fetching issuer public keys)
JWKS_CACHE_TTL_SECONDS=300

# Audit signing key (generated on first start if not set)
AUDIT_SIGNING_KEY_FILE=

# Delegation defaults
MAX_DELEGATION_DEPTH=5
REQUIRE_ATTENUATION_PROOF=true
