# Portable Authorization — Issuer Service
PORT=3100
NODE_ENV=development

# PostgreSQL (shared instance, portauth_ table prefix)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portauth

# Admin API key for issuance endpoints
ADMIN_API_KEY=dev-issuer-key-change-me

# Signing key algorithm (ES256 for Phase 1)
SIGNING_ALGORITHM=ES256

# Tier 2 X.509 issuance. Use PKCS8 private keys.
X509_PRIVATE_KEY_PEM=
X509_CERT_CHAIN_PEM=
X509_ISSUER_ID=
X509_SIGNING_ALGORITHM=ES256

# Key rotation interval in days (0 = manual only)
KEY_ROTATION_DAYS=0

# Credential defaults
DEFAULT_TTL_HOURS=24
MAX_TTL_HOURS=720
