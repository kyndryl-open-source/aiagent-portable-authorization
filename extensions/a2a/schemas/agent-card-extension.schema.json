{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyndryl-open-source.github.io/aiagent-portable-authorization/a2a/v1/agent-card-extension.schema.json",
  "title": "PortAuth A2A Agent Card extension declaration",
  "type": "object",
  "required": ["uri", "required", "params"],
  "properties": {
    "uri": {
      "const": "https://kyndryl-open-source.github.io/aiagent-portable-authorization/a2a/v1"
    },
    "description": { "type": "string" },
    "required": { "type": "boolean" },
    "params": {
      "type": "object",
      "required": ["governanceManifestUrl", "acceptedProfiles"],
      "properties": {
        "governanceManifestUrl": { "type": "string", "format": "uri" },
        "acceptedProfiles": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["tier1-jwt", "tier2-x509-jwt", "tier3-vc-jose"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "acceptedAudiences": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
