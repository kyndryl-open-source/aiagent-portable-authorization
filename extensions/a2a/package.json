{
  "private": true,
  "type": "module",
  "workspaces": [
    "sdk",
    "receiver-middleware",
    "reference-receiver",
    "reference-presenter",
    "reference-intermediate"
  ],
  "devDependencies": {
    "pg": "^8.13.0"
  },
  "scripts": {
    "install:local": "npm install",
    "test": "node --test tests/*.test.js",
    "receiver": "node reference-receiver/src/server.js",
    "two-hop": "node reference-intermediate/src/demo-two-hop.js",
    "presenter": "node reference-presenter/src/send-bill-payment.js",
    "allow": "node reference-presenter/src/send-bill-payment.js allow",
    "deny": "node reference-presenter/src/send-bill-payment.js deny-amount",
    "tls:cert": "sh tls/generate-localhost-cert.sh",
    "tls:up": "cd ../.. && docker compose -f portauth-docker-compose.yml -f extensions/a2a/docker-compose.tls.yml up -d --build",
    "tls:down": "cd ../.. && docker compose -f portauth-docker-compose.yml -f extensions/a2a/docker-compose.tls.yml down -v"
  }
}
